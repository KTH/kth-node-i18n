{
  "name": "kth-node-i18n",
  "version": "2.0.0",
  "description": "i18n module for both browser and Node.js.",
  "main": "index.js",
  "files": [
    "index.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "author": {
    "name": "KTH",
    "email": "infosys@kth.se",
    "url": "https://github.com/KTH"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint \"**/*.js\" --quiet",
    "lint-v": "eslint \"**/*.js\" ",
    "test": "jest",
    "build": "./build.sh",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KTH/kth-node-i18n.git"
  },
  "keywords": [
    "node",
    "i18n"
  ],
  "devDependencies": {
    "@kth/eslint-config-kth": "^4.1.0",
    "eslint": "^9.39.5",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-extended": "^7.0.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  },
  "jest": {
    "clearMocks": true,
    "setupFilesAfterEnv": [
      "jest-extended/all"
    ],
    "testEnvironment": "node",
    "verbose": true
  },
  "// (prettier)": "configuration version 2020-06-15 - might also reside in .prettierrc.json",
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 120,
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5"
  }
